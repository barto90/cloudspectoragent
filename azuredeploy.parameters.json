{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "containerGroupName": {
      "value": "cloudspector-agent"
    },
    "storageAccountName": {
      "value": "csagent<unique-suffix>"
    },
    "fileShareName": {
      "value": "cloudspector-data"
    },
    "agentImageName": {
      "value": "7nodeit.azurecr.io/cloudspector.agent:latest"
    },
    "acrTokenUsername": {
      "value": "<your-acr-token-name>"
    },
    "acrTokenPassword": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.KeyVault/vaults/<vault-name>"
        },
        "secretName": "cloudspector-acr-token-password"
      }
    },
    "authPepper": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.KeyVault/vaults/<vault-name>"
        },
        "secretName": "cloudspector-auth-pepper"
      }
    },
    "cloudSpectorApiBaseUrl": {
      "value": "https://cloudspectorapi.redcoast-8186da07.westeurope.azurecontainerapps.io"
    },
    "sqlServerName": {
      "value": "csagent-sql-<unique-suffix>"
    },
    "sqlDatabaseName": {
      "value": "cloudspector-agent-db"
    },
    "sqlDatabaseSkuName": {
      "value": "Basic"
    }
  }
}
