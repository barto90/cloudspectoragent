{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "containerGroupName": {
      "type": "string",
      "metadata": {
        "description": "Name for the Azure Container Instance resource. Must be unique within the resource group."
      }
    },
    "storageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Globally unique storage account name (3–24 characters, lowercase letters and numbers only). Example: csagentcontoso001"
      }
    },
    "fileShareName": {
      "type": "string",
      "defaultValue": "cloudspector-data",
      "metadata": {
        "description": "Azure Files share name. The agent mounts this share at /data for persistent storage of provider packages (not the database — see sqlServerName)."
      }
    },
    "agentImageName": {
      "type": "string",
      "defaultValue": "7nodeit.azurecr.io/cloudspector.agent:latest",
      "metadata": {
        "description": "Full container image reference. Change only if instructed by 7NodeIT support."
      }
    },
    "acrTokenUsername": {
      "type": "string",
      "metadata": {
        "description": "ACR repository-scoped token name provided by 7NodeIT. This is a token name, not a password — it is not secret."
      }
    },
    "acrTokenPassword": {
      "type": "securestring",
      "metadata": {
        "description": "ACR repository-scoped token password provided by 7NodeIT. Store this in Azure Key Vault and reference it here."
      }
    },
    "authPepper": {
      "type": "securestring",
      "metadata": {
        "description": "REQUIRED — type your own random string of at least 32 characters (letters/numbers/symbols), store it in Azure Key Vault, and reference it here. This is used by the agent to hash user passwords (PBKDF2-SHA512). It is not provided by 7NodeIT — you generate it yourself, once. IMPORTANT: if this value is ever lost, existing agent user passwords can no longer be verified and all accounts must be recreated."
      }
    },
    "cloudSpectorApiBaseUrl": {
      "type": "string",
      "defaultValue": "https://cloudspectorapi.redcoast-8186da07.westeurope.azurecontainerapps.io",
      "metadata": {
        "description": "CloudSpector backend API URL. Used by the agent when running in Online connectivity mode. Do not change unless instructed by 7NodeIT."
      }
    },
    "sqlServerName": {
      "type": "string",
      "metadata": {
        "description": "Globally unique Azure SQL logical server name (lowercase letters, numbers, hyphens, 1-63 characters). Example: csagent-sql-contoso001"
      }
    },
    "sqlDatabaseName": {
      "type": "string",
      "defaultValue": "cloudspector-agent-db",
      "metadata": {
        "description": "Name of the Azure SQL Database that stores the agent's local data (baselines, design decisions, users, feed items, check metadata)."
      }
    },
    "sqlDatabaseSkuName": {
      "type": "string",
      "defaultValue": "Basic",
      "allowedValues": [
        "Basic",
        "S0",
        "S1"
      ],
      "metadata": {
        "description": "Azure SQL Database pricing tier. Basic (~€4-5/month) is sufficient for the agent's lightweight local database; upgrade to S0/S1 only if you experience performance issues."
      }
    }
  },
  "variables": {
    "location": "[resourceGroup().location]"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-01-01",
      "name": "[parameters('storageAccountName')]",
      "location": "[variables('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "supportsHttpsTrafficOnly": true,
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
      "apiVersion": "2023-01-01",
      "name": "[concat(parameters('storageAccountName'), '/default/', parameters('fileShareName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
      ],
      "properties": {
        "shareQuota": 32
      }
    },
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerGroupName')]",
      "location": "[variables('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/fileServices/shares', parameters('storageAccountName'), 'default', parameters('fileShareName'))]"
      ],
      "properties": {
        "containers": [
          {
            "name": "cloudspector-agent",
            "properties": {
              "image": "[parameters('agentImageName')]",
              "resources": {
                "requests": {
                  "cpu": 1,
                  "memoryInGB": 1.5
                }
              },
              "ports": [
                {
                  "port": 8080,
                  "protocol": "TCP"
                }
              ],
              "environmentVariables": [
                {
                  "name": "ASPNETCORE_ENVIRONMENT",
                  "value": "Production"
                },
                {
                  "name": "PersistentStorage__Path",
                  "value": "/data"
                },
                {
                  "name": "CLOUDSPECTOR_DATA_PATH",
                  "value": "/data"
                },
                {
                  "name": "Auth__Pepper",
                  "secureValue": "[parameters('authPepper')]"
                },
                {
                  "name": "CloudSpectorApi__BaseUrl",
                  "value": "[parameters('cloudSpectorApiBaseUrl')]"
                },
                {
                  "name": "ConnectionStrings__CloudSpector",
                  "value": "[concat('Server=tcp:', parameters('sqlServerName'), '.database.windows.net,1433;Initial Catalog=', parameters('sqlDatabaseName'), ';Authentication=Active Directory Managed Identity;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;')]"
                }
              ],
              "volumeMounts": [
                {
                  "name": "cloudspector-data",
                  "mountPath": "/data"
                }
              ]
            }
          }
        ],
        "imageRegistryCredentials": [
          {
            "server": "7nodeit.azurecr.io",
            "username": "[parameters('acrTokenUsername')]",
            "password": "[parameters('acrTokenPassword')]"
          }
        ],
        "osType": "Linux",
        "restartPolicy": "Always",
        "ipAddress": {
          "type": "Public",
          "ports": [
            {
              "port": 8080,
              "protocol": "TCP"
            }
          ]
        },
        "volumes": [
          {
            "name": "cloudspector-data",
            "azureFile": {
              "shareName": "[parameters('fileShareName')]",
              "storageAccountName": "[parameters('storageAccountName')]",
              "storageAccountKey": "[listKeys(resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName')), '2023-01-01').keys[0].value]"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Sql/servers",
      "apiVersion": "2022-05-01-preview",
      "name": "[parameters('sqlServerName')]",
      "location": "[variables('location')]",
      "comments": "No SQL login/password is created. Azure AD-only authentication with the Container Group's system-assigned managed identity as the sole server administrator (see ADR-043). This resource depends on the Container Group purely to read its identity.principalId/tenantId at deploy time — the container itself does not wait for the SQL Server to exist before starting (its connection string is derived from parameters, not from a runtime reference), so it may restart a few times while the database finishes provisioning. This is expected; restartPolicy is 'Always'.",
      "dependsOn": [
        "[resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName'))]"
      ],
      "properties": {
        "version": "12.0",
        "administrators": {
          "administratorType": "ActiveDirectory",
          "principalType": "Application",
          "login": "[parameters('containerGroupName')]",
          "sid": "[reference(resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName')), '2023-05-01', 'Full').identity.principalId]",
          "tenantId": "[reference(resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName')), '2023-05-01', 'Full').identity.tenantId]",
          "azureADOnlyAuthentication": true
        }
      }
    },
    {
      "type": "Microsoft.Sql/servers/firewallRules",
      "apiVersion": "2021-11-01",
      "name": "[concat(parameters('sqlServerName'), '/AllowAzureServices')]",
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', parameters('sqlServerName'))]"
      ],
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      }
    },
    {
      "type": "Microsoft.Sql/servers/databases",
      "apiVersion": "2021-11-01",
      "name": "[concat(parameters('sqlServerName'), '/', parameters('sqlDatabaseName'))]",
      "location": "[variables('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', parameters('sqlServerName'))]"
      ],
      "sku": {
        "name": "[parameters('sqlDatabaseSkuName')]"
      },
      "properties": {
        "collation": "SQL_Latin1_General_CP1_CI_AS"
      }
    }
  ],
  "outputs": {
    "containerPublicIp": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName'))).ipAddress.ip]"
    },
    "agentUrl": {
      "type": "string",
      "value": "[concat('http://', reference(resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName'))).ipAddress.ip, ':8080')]"
    },
    "sqlServerFqdn": {
      "type": "string",
      "value": "[concat(parameters('sqlServerName'), '.database.windows.net')]"
    },
    "sqlDatabaseName": {
      "type": "string",
      "value": "[parameters('sqlDatabaseName')]"
    }
  }
}
